  "meta": {
    "title": "0rbital — Co-living Founder Programs",
    "compiled": "2026-07-01",
    "scope": "Co-living founder programs only: founder residencies and hacker/founder houses where people live and build together for a fixed term. Every record is a live-in / residential cohort (canonicalType founder-residency or hacker-house, or format live-in). Categorized by the canonical program taxonomy (see src/data/taxonomy.ts).",
    "note": "Recruiting status reflects best-available public info as of June 2026 and changes frequently. Always confirm on the program's own site. Logos are self-hosted (collected by scripts/fetch-logos.ts into public/logos/, indexed by src/lib/logoManifest.json) and served local-first, falling back to live DuckDuckGo → Google favicon services and finally an initials placeholder. Every program domain has a logo: programs whose site publishes none get a generated SVG monogram so no marker is blank.",
    "status_legend": {
      "open": "Applications are open (rolling or a current cohort window)",
      "coming-soon": "Announced but not open/launched yet",
      "running": "Cohort currently in session",
      "closed": "Applications closed; check the site for the next cycle"
    }
  },
