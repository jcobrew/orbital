---
import '../styles/global.css';
import IntroOverlay from '../components/IntroOverlay.tsx';
import CountryDetailDrawer from '../components/CountryDetailDrawer.tsx';
import CompareTray from '../components/CompareTray.tsx';
import CompareDrawer from '../components/CompareDrawer.tsx';
import ApplyTrackPrompt from '../components/ApplyTrackPrompt.tsx';
import { PROGRAMS } from '../data/programs';

interface Props {
  title: string;
  description?: string;
  /** Hide overflow + lock height for the full-screen map/globe pages. */
  fullscreen?: boolean;
}

const { title, description, fullscreen = false } = Astro.props;

// The intro overlay auto-opens (once ever) only on the entry surfaces.
const autoIntro = ['/', '/explore'].includes(Astro.url.pathname);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body class={fullscreen ? 'h-screen overflow-hidden' : 'min-h-screen'}>
    <slot />
    <IntroOverlay autoOpen={autoIntro} client:load />
    <CountryDetailDrawer client:load />
    {/* Compare is driven from the scroll surfaces; keep its tray/drawer off the
        immersive full-screen globe/map so it can't overlap their controls. */}
    {!fullscreen && (
      <>
        <CompareTray programs={PROGRAMS} client:load />
        <CompareDrawer programs={PROGRAMS} client:load />
      </>
    )}
    <ApplyTrackPrompt client:load />
  </body>
</html>
