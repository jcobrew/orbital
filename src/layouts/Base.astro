---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Hide overflow + lock height for the full-screen map/globe pages. */
  fullscreen?: boolean;
}

const { title, description, fullscreen = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body class={fullscreen ? 'h-screen overflow-hidden' : 'min-h-screen'}>
    <slot />
  </body>
</html>
