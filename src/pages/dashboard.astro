---
import Base from '../layouts/Base.astro';
import SiteNav from '../components/SiteNav.tsx';
import FilterSidebar from '../components/FilterSidebar.tsx';
import ProgramsTable from '../components/ProgramsTable.tsx';
import { PROGRAMS } from '../data/programs';

// Server-rendered schema.org JSON-LD for the full catalog — ships in the HTML
// so agents/crawlers get structured records without running JS.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '0rbital — founder residencies, hacker houses, startup campuses & co-living programs',
  numberOfItems: PROGRAMS.length,
  itemListElement: PROGRAMS.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'EducationalOccupationalProgram',
      name: p.name,
      programType: p.type,
      url: p.url,
      provider: p.operator ? { '@type': 'Organization', name: p.operator } : undefined,
      areaServed: [p.city, p.country].filter(Boolean).join(', '),
      occupationalCategory: p.focus,
      description: p.status_detail || p.highlight || undefined,
      dateModified: p.lastVerified || undefined,
    },
  })),
};
---

<Base
  title="Data quality dashboard — 0rbital"
  description="Track freshness, verification status, missing fields, and builder environments that need review in 0rbital."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} slot="head" />

  <header class="mx-auto max-w-[1400px] px-7 pt-5">
    <SiteNav current="dashboard" client:load />
    <h1
      class="m-0 mb-2 mt-5 flex items-center gap-2 font-display text-[24px] font-bold leading-[1.15]"
      style="color:var(--text)"
    >
      <span class="orbit-node" aria-hidden="true"></span>Data quality dashboard
    </h1>
    <p class="mb-1.5 max-w-[680px] text-[13px] leading-normal text-muted">
      Track freshness, verification status, missing fields, and programs that need review. Drive every filter by URL, share deep links, or pull the data straight from the <a href="/api/programs.json" class="font-semibold">JSON API</a> and <a href="/llms.txt" class="font-semibold">llms.txt</a>. Status as of June 2026 — always confirm on each site.
    </p>
  </header>

  <main class="mx-auto max-w-[1400px] px-7 pb-16 pt-4">
    <div class="mb-3.5">
      <FilterSidebar programs={PROGRAMS} variant="dashboard" client:load />
    </div>
    <ProgramsTable programs={PROGRAMS} client:load />
  </main>

  <footer class="mx-auto max-w-[1400px] px-7 pb-12 text-[12px] leading-relaxed text-muted">
    <p>
      <strong>For agents:</strong> this page is fully URL-navigable. Compose filters with
      <code class="rounded bg-[rgba(16,16,16,.6)] px-1.5 py-px text-a2"
        >?q=…&amp;model=&lt;co-living|co-working|both&gt;&amp;country=…&amp;status=…&amp;sort=…&amp;dir=-1</code
      >. The canonical machine data is
      <code class="rounded bg-[rgba(16,16,16,.6)] px-1.5 py-px text-a2">/api/programs.json</code>; discovery lives at
      <code class="rounded bg-[rgba(16,16,16,.6)] px-1.5 py-px text-a2">/llms.txt</code>. Each program also has schema.org JSON-LD.
    </p>
  </footer>
</Base>
