---
import Base from '../layouts/Base.astro';
import GlobeView from '../islands/GlobeView.tsx';
import { PROGRAMS } from '../data/programs';
---

<Base
  title="Orbital — Find where founders gather"
  description="A live map of founder residencies, hacker houses and co-living programs worldwide — where founders live and build together. Explore on a 3D globe or a filterable list — by stage, sector, housing, location and application status."
  fullscreen
>
  <!-- Small screens go straight to the list; the globe is the desktop entry. -->
  <script slot="head" is:inline>
    if (window.matchMedia('(max-width: 760px)').matches) {
      window.location.replace('/explore' + window.location.search + window.location.hash);
    }
  </script>
  <!-- Globe.gl (Three.js) needs the DOM; render this island client-only. -->
  <GlobeView programs={PROGRAMS} client:only="react" />
  <div slot="head"></div>
</Base>
