---
import Base from '../layouts/Base.astro';
import GlobeView from '../islands/GlobeView.tsx';
import { PROGRAMS } from '../data/programs';
---

<Base
  title="Founder Atlas — 3D Globe of the best places to build"
  description="A 3D globe of the best places for founders to build — relocation programs and startup support worldwide. Spin the globe or pick a program to fly there; dense cities have their own minimaps below."
  fullscreen
>
  <!-- Globe.gl (Three.js) needs the DOM; render this island client-only. -->
  <GlobeView programs={PROGRAMS} client:only="react" />
  <div slot="head"></div>
</Base>
