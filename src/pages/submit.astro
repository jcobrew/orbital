---
import Base from '../layouts/Base.astro';
import SiteNav from '../components/SiteNav.tsx';
import SubmitForm from '../components/SubmitForm.tsx';
---

<Base
  title="Submit a builder environment — 0rbital"
  description="Know a founder residency, hacker house, startup campus, or co-living program we should include? Submit it to 0rbital for review."
>
  <header class="mx-auto max-w-[920px] px-7 pt-5">
    <SiteNav current="about" client:load />
  </header>

  <main class="mx-auto max-w-[920px] px-7 pb-16 pt-8">
    <h1 class="m-0 mb-2 flex items-center gap-2 font-display text-[26px] font-bold leading-[1.12] text-text">
      <span class="orbit-node" aria-hidden="true"></span>Add a builder environment
    </h1>
    <p class="m-0 mb-6 max-w-[640px] text-[13.5px] leading-relaxed text-muted">
      Know a founder residency, hacker house, startup campus, or co-living program we should include? Submit it for review. Submitting opens a <strong>prefilled GitHub issue</strong> (you'll need a GitHub account) that we verify against primary sources before it goes live — we never publish unverified data. Only fill what you know; leave the rest blank.
    </p>

    <SubmitForm client:load />
  </main>
</Base>
