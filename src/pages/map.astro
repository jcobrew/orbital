---
import Base from '../layouts/Base.astro';
import MapView from '../islands/MapView.tsx';
import { PROGRAMS } from '../data/programs';
---

<Base
  title="Founder Atlas — Map of the best places to build"
  description="Founder Atlas maps the best places in the world for founders to relocate and the startup support waiting there — residencies, hacker houses, startup campuses, accelerators & incubators."
  fullscreen
>
  <!-- Leaflet needs the DOM; render this island client-only. -->
  <MapView programs={PROGRAMS} client:only="react" />
  <div slot="head"></div>
</Base>
