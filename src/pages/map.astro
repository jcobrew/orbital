---
import Base from '../layouts/Base.astro';
import MapView from '../islands/MapView.tsx';
import { PROGRAMS } from '../data/programs';
---

<Base
  title="Orbital — Map of where founders gather"
  description="Orbital maps the residencies, hacker houses and co-living programs where founders live and build together — the places with enough gravity to pull people across the world."
  fullscreen
>
  <!-- Leaflet needs the DOM; render this island client-only. -->
  <MapView programs={PROGRAMS} client:only="react" />
  <div slot="head"></div>
</Base>
