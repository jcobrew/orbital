---
import Base from '../layouts/Base.astro';
import SiteNav from '../components/SiteNav.tsx';
import CountryGridCard from '../components/CountryGridCard.tsx';
import { COUNTRIES } from '../data/countries';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Orbital — country startup-ecosystem directories',
  numberOfItems: COUNTRIES.length,
  itemListElement: COUNTRIES.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: { '@type': 'Country', name: c.name, description: c.summary },
  })),
};
---

<Base
  title="Orbital — country startup-ecosystem directories"
  description="Deciding where to land? For each country, Orbital points you to the local startup-ecosystem directories and portals worth knowing — plus the co-living programs drawing founders there."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} slot="head" />

  <header class="mx-auto max-w-[1100px] px-7 pt-6">
    <SiteNav current="countries" client:load />
    <div class="mt-5"></div>
    <h1
      class="m-0 mb-2 font-display text-[26px] font-bold leading-[1.15]"
      style="color:var(--text)"
    >
      Where founders are landing
    </h1>
    <p class="mb-1.5 max-w-[680px] text-[13px] leading-normal text-muted">
      Weighing where to build next? Orbital points you outward — to the local startup-ecosystem directories
      and portals worth knowing in each country — and shows the co-living programs drawing founders there.
      Tap a country to open its directories.
    </p>
  </header>

  <main class="mx-auto max-w-[1100px] px-7 pb-16 pt-4">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {COUNTRIES.map((c) => (
        <CountryGridCard
          client:visible
          slug={c.slug}
          name={c.name}
          region={c.region}
          summary={c.summary}
          programCount={c.programCount}
          hasGuides={Boolean(c.business || c.relocation)}
        />
      ))}
    </div>
  </main>
</Base>
