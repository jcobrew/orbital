---
import Base from '../../layouts/Base.astro';
import SiteNav from '../../components/SiteNav.tsx';
import { CITIES, getCity } from '../../data/cities';
import { programSlug } from '../../data/programs';
import { statusMeta } from '../../lib/status';
import { livingModelLabel } from '../../lib/living';
import { countrySlug, hasCountryProfile } from '../../data/countries';
import { defaultSort } from '../../lib/filter';

export function getStaticPaths() {
  return CITIES.map((c) => ({ params: { slug: c.slug } }));
}

const city = getCity(Astro.params.slug!)!;
const programs = defaultSort(city.programs);
const hasCountry = hasCountryProfile(city.country);

// Living-model mix (skip unknowns).
const models = [...new Set(programs.map((p) => livingModelLabel(p.format)).filter(Boolean))] as string[];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Startup programs in ${city.city}, ${city.country}`,
  numberOfItems: programs.length,
  itemListElement: programs.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: { '@type': 'EducationalOccupationalProgram', name: p.name, url: p.url, programType: p.type },
  })),
};

const title = `Startup Programs in ${city.city} — Founder Atlas`;
const description = `Accelerators, incubators, residencies, hacker houses and fellowships in ${city.city}, ${city.country}. ${programs.length} program${programs.length === 1 ? '' : 's'} with stage fit, funding, housing and application status.`;
---

<Base title={title} description={description}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} slot="head" />

  <header class="mx-auto max-w-[920px] px-7 pt-5">
    <SiteNav current="list" client:load />
    <a href="/explore" class="mt-5 inline-block text-[12px] text-muted hover:text-text">← All programs</a>
  </header>

  <main class="mx-auto max-w-[920px] px-7 pb-16 pt-4">
    <h1 class="m-0 font-display text-[28px] font-bold leading-[1.1] text-text">{city.city}</h1>
    <div class="mt-1.5 text-[13px] text-muted">
      {
        hasCountry ? (
          <a href={`/country/${countrySlug(city.country)}`} class="font-semibold">{city.country} ↗</a>
        ) : (
          <span>{city.country}</span>
        )
      }
      <span> · {programs.length} program{programs.length === 1 ? '' : 's'}</span>
    </div>

    {
      models.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {models.map((m) => (
            <span class="rounded-[3px] border border-line2 px-2 py-0.5 text-[10.5px] font-semibold uppercase tracking-wide text-muted">
              {m}
            </span>
          ))}
        </div>
      )
    }

    <div class="mt-5 flex flex-wrap gap-2.5">
      <a
        href={`/explore?q=${encodeURIComponent(city.city)}`}
        class="rounded-[3px] border border-line2 px-4 py-2 font-display text-[12.5px] font-semibold text-text no-underline transition hover:border-a1"
      >
        Filter the list to {city.city} →
      </a>
    </div>

    <!-- Program list -->
    <section class="mt-8">
      <h2 class="m-0 mb-3 font-display text-[15px] font-bold text-text">Programs in {city.city}</h2>
      <div class="overflow-hidden rounded-[3px] border border-line">
        {
          programs.map((p) => {
            const s = statusMeta(p.status);
            const living = livingModelLabel(p.format);
            return (
              <a
                href={`/programs/${programSlug(p.name)}`}
                class="flex items-center gap-3 border-b border-line px-4 py-3 no-underline transition last:border-b-0 hover:bg-[rgba(255,255,255,.06)]"
              >
                <span class="h-2 w-2 flex-none rounded-full" style={`background:${s.color}`} title={s.label} />
                <span class="min-w-0 flex-1">
                  <span class="block truncate text-[13.5px] font-semibold text-text">{p.name}</span>
                  <span class="block truncate text-[11.5px] text-muted">{p.type}</span>
                </span>
                {living && <span class="flex-none text-[10.5px] font-semibold uppercase tracking-wide text-muted">{living}</span>}
              </a>
            );
          })
        }
      </div>
    </section>
  </main>
</Base>
