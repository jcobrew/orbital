---
import Base from '../layouts/Base.astro';
import SiteNav from '../components/SiteNav.tsx';
import ProgramTypeExplainer from '../components/ProgramTypeExplainer.astro';
import FounderTriggers from '../components/FounderTriggers.tsx';
import { PROGRAMS, FACETS } from '../data/programs';

const countryCount = Object.keys(FACETS.country).length;
---

<Base
  title="About — Orbital"
  description="What Orbital is and how to use it: a live map of founder residencies, hacker houses and co-living programs where founders live and build together, filterable by stage, sector, housing, location and application status."
>
  <header class="mx-auto max-w-[1100px] px-7 pt-5">
    <SiteNav current="about" client:load />
  </header>

  <section class="mx-auto max-w-[1100px] px-7 pb-6 pt-10">
    <h1 class="m-0 mb-4 max-w-[760px] font-display text-[32px] font-bold leading-[1.08] text-text sm:text-[40px]">
      Find where founders gather.
    </h1>
    <p class="m-0 mb-6 max-w-[680px] text-[15px] leading-relaxed text-muted">
      Orbital maps the residencies, hacker houses and co-living programs where founders live and build
      together — the places with enough gravity to pull people across the world. {PROGRAMS.length} programs across
      {countryCount} countries. Filter by stage, sector, location, housing and
      application status to find the place that pulls you in.
    </p>
    <div class="flex flex-wrap items-center gap-3">
      <a
        href="/"
        class="rounded-[3px] border border-transparent px-5 py-3 font-display text-[13.5px] font-bold text-[#0a0a0a] no-underline"
        style="background:var(--grad)"
      >
        Explore the globe
      </a>
      <a
        href="/explore"
        class="rounded-[3px] border border-line2 px-5 py-3 font-display text-[13px] font-semibold text-text no-underline transition hover:border-a1"
      >
        Browse the list
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-[1100px] px-7 pt-4">
    <FounderTriggers mode="link" client:load />
  </section>

  <ProgramTypeExplainer />

  <section class="mx-auto max-w-[1100px] px-7 py-8">
    <h2 class="m-0 mb-2 font-display text-[18px] font-bold text-text">How to use it</h2>
    <ul class="m-0 max-w-[680px] list-disc pl-5 text-[13px] leading-relaxed text-muted">
      <li>Switch between <strong>Globe</strong>, <strong>Map</strong> and <strong>List</strong> — your filters carry across all three.</li>
      <li>Open any program for the practical trade-offs: funding, equity, housing, format, deadlines. Missing details show as <em>Unknown</em> — we don't guess.</li>
      <li>Go up a level to whole <a href="/countries" class="font-semibold">country ecosystems</a> if you're weighing where to relocate.</li>
    </ul>
  </section>

  <section class="mx-auto max-w-[1100px] px-7 py-4">
    <div class="rounded-[3px] border border-line bg-[rgba(10,13,28,.55)] p-6">
      <h2 class="m-0 mb-1.5 font-display text-[18px] font-bold text-text">Know a program we missed?</h2>
      <p class="m-0 mb-4 max-w-[620px] text-[13px] leading-relaxed text-muted">
        Add a program, fix a deadline, or correct outdated terms. It takes a minute and helps every founder after you.
      </p>
      <a
        href="/submit"
        class="inline-block rounded-[3px] border border-line2 px-4 py-2.5 font-display text-[13px] font-semibold text-text no-underline transition hover:border-a1"
      >
        Submit or update a program →
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-[1100px] px-7 pb-16">
    <h2 class="m-0 mb-2 font-display text-[18px] font-bold text-text">Data & trust</h2>
    <p class="m-0 mb-3 max-w-[680px] text-[13px] leading-relaxed text-muted">
      Status reflects best-available public info as of June 2026 and changes often — always confirm on
      the official site before applying. Building agents? Everything is available as structured data at
      <a href="/api/programs.json" class="font-semibold">/api/programs.json</a>,
      <a href="/api/countries.json" class="font-semibold">/api/countries.json</a> and
      <a href="/llms.txt" class="font-semibold">/llms.txt</a>, and the
      <a href="/dashboard" class="font-semibold">dashboard</a> is a fully URL-navigable table.
    </p>
  </section>
</Base>
