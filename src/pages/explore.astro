---
import Base from '../layouts/Base.astro';
import ViewNav from '../components/ViewNav.astro';
import ViewToggle from '../components/ViewToggle.tsx';
import FilterSidebar from '../components/FilterSidebar.tsx';
import ExploreResults from '../components/ExploreResults.tsx';
import { PROGRAMS } from '../data/programs';

const submitting = Astro.url.searchParams.get('intent') === 'submit';
---

<Base
  title="Explore startup programs — Founder Atlas"
  description="Search and filter startup accelerators, incubators, founder residencies, hacker houses and fellowships by stage, sector, funding, housing, location and application status. Open any program for the full trade-offs."
>
  <header class="mx-auto max-w-[1400px] px-7 pt-6">
    <div class="mb-2 font-display text-[10.5px] font-semibold uppercase tracking-[.22em] text-a2">
      Founder Atlas · Explore · 2026
    </div>
    <div class="mb-3.5 flex flex-wrap items-center justify-between gap-3">
      <div class="max-w-[520px] flex-1">
        <ViewNav current="explore" />
      </div>
      <ViewToggle current="list" client:load />
    </div>
    <h1 class="m-0 mb-1.5 font-display text-[24px] font-bold leading-[1.15] text-text">
      Find the right startup program
    </h1>
    <p class="m-0 mb-1.5 max-w-[680px] text-[13px] leading-normal text-muted">
      Filter by type, country, and application status, then open a program to compare funding, equity,
      housing, format, and deadlines. Missing details show as <em>Unknown</em> — we don't guess.
    </p>
  </header>

  {
    submitting && (
      <div class="mx-auto mt-2 max-w-[1400px] px-7">
        <div class="rounded-md border border-line2 bg-[rgba(10,13,28,.7)] p-4 text-[12.5px] text-muted">
          <strong class="text-text">Submissions are coming soon.</strong> A structured submit/update form is
          on the roadmap. In the meantime, browse the directory below — and thanks for helping keep it current.
        </div>
      </div>
    )
  }

  <main class="mx-auto max-w-[1400px] px-7 pb-16 pt-4">
    <div class="mb-4">
      <FilterSidebar programs={PROGRAMS} variant="dashboard" client:load />
    </div>
    <ExploreResults programs={PROGRAMS} client:load />
  </main>
</Base>
