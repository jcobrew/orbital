---
import Base from '../../layouts/Base.astro';
import SiteNav from '../../components/SiteNav.tsx';
import { COUNTRIES, getCountry } from '../../data/countries';
import { PROGRAMS, programSlug } from '../../data/programs';
import { citiesInCountry, citySlug } from '../../data/cities';
import { statusMeta } from '../../lib/status';
import { livingModelLabel } from '../../lib/living';
import { defaultSort } from '../../lib/filter';
import { flagSrc } from '../../lib/flag';

// One static page per country profile. As the dataset grows (or moves to a
// cloud DB), this list grows automatically — no per-page wiring needed.
export function getStaticPaths() {
  return COUNTRIES.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const country = getCountry(slug!);
if (!country) return Astro.redirect('/');

const dashboardHref = `/dashboard?country=${encodeURIComponent(country.name)}`;
const flag = flagSrc(country.slug);
const programs = defaultSort(PROGRAMS.filter((p) => p.country === country.name));
const cities = citiesInCountry(country.name);

// schema.org Country so agents/crawlers get a structured record.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Country',
  name: country.name,
  description: country.summary,
};
---

<Base
  title={`Orbital — ${country.name} startup ecosystem`}
  description={country.summary}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} slot="head" />

  <header class="mx-auto max-w-[900px] px-7 pt-6">
    <SiteNav current="list" client:load />
    <a href="/" class="mt-5 inline-block text-[12px] text-muted hover:text-text">← Back to the globe</a>
    <div class="mb-2 mt-1 flex items-center gap-3">
      {flag && (
        <img
          src={flag}
          alt={`${country.name} flag`}
          width={40}
          height={40}
          class="h-10 w-10 shrink-0 rounded-full ring-1 ring-line2"
        />
      )}
      <h1
        class="m-0 font-display text-[30px] font-bold leading-[1.12]"
        style="color:var(--text)"
      >
        {country.name}
      </h1>
    </div>
    <div class="mb-3 flex flex-wrap items-center gap-2 text-[12px] text-muted">
      <span class="rounded-[3px] border border-line2 px-2.5 py-1">{country.region}</span>
      <a href={dashboardHref} class="rounded-[3px] border border-line2 px-2.5 py-1 font-semibold text-text hover:border-a1">
        {country.programCount} program{country.programCount === 1 ? '' : 's'} on the map →
      </a>
    </div>
    <p class="mb-1.5 max-w-[680px] text-[14px] leading-relaxed text-text">{country.summary}</p>
  </header>

  <main class="mx-auto max-w-[900px] px-7 pb-16 pt-4 flex flex-col gap-7">
    <section>
      <h2 class="mb-1.5 font-display text-[15px] font-semibold text-text">Start here</h2>
      <p class="mb-2.5 max-w-[640px] text-[12.5px] leading-relaxed text-muted">
        Rather than re-collect every detail, Orbital points you outward — to the two official portals
        worth knowing in {country.name}: where the ecosystem lives, and how to move in.
      </p>
      {country.business || country.relocation ? (
        <div class="grid gap-3 sm:grid-cols-2">
          {country.business && (
            <a
              href={country.business.url}
              target="_blank"
              rel="noopener"
              class="orbit-hover rounded-2xl border border-line2 bg-[rgba(16,16,16,.5)] p-4 transition hover:border-a1"
            >
              <div class="mb-1 text-[10.5px] font-semibold uppercase tracking-wide text-a2">Business & ecosystem</div>
              <div class="mb-1 text-[13.5px] font-semibold text-text">{country.business.label} ↗</div>
              {country.business.description && (
                <div class="text-[12.5px] leading-relaxed text-muted">{country.business.description}</div>
              )}
            </a>
          )}
          {country.relocation && (
            <a
              href={country.relocation.url}
              target="_blank"
              rel="noopener"
              class="orbit-hover rounded-2xl border border-line2 bg-[rgba(16,16,16,.5)] p-4 transition hover:border-a1"
            >
              <div class="mb-1 text-[10.5px] font-semibold uppercase tracking-wide text-a2">Moving in</div>
              <div class="mb-1 text-[13.5px] font-semibold text-text">{country.relocation.label} ↗</div>
              {country.relocation.description && (
                <div class="text-[12.5px] leading-relaxed text-muted">{country.relocation.description}</div>
              )}
            </a>
          )}
        </div>
      ) : (
        <p class="text-[12.5px] italic leading-relaxed text-muted">
          Local guides coming soon.
        </p>
      )}
    </section>

    <hr class="orbit-divider my-0" />

    {programs.length > 0 && (
      <section>
        <h2 class="mb-2.5 font-display text-[15px] font-semibold text-text">Programs in {country.name}</h2>
        {cities.length > 1 && (
          <div class="mb-3 flex flex-wrap gap-1.5">
            {cities.map((c) => (
              <a
                href={`/cities/${c.slug}`}
                class="rounded-[3px] border border-line2 px-2.5 py-1 text-[11.5px] font-semibold text-muted no-underline transition hover:border-a1 hover:text-text"
              >
                {c.city} <span class="opacity-60">{c.count}</span>
              </a>
            ))}
          </div>
        )}
        <div class="overflow-hidden rounded-[3px] border border-line">
          {programs.map((p) => {
            const s = statusMeta(p.status);
            const living = livingModelLabel(p.format);
            return (
              <a
                href={`/programs/${programSlug(p.name)}`}
                class="flex items-center gap-3 border-b border-line px-4 py-2.5 no-underline transition last:border-b-0 hover:bg-[rgba(255,255,255,.06)]"
              >
                <span class="h-2 w-2 flex-none rounded-full" style={`background:${s.color}`} title={s.label} />
                <span class="min-w-0 flex-1">
                  <span class="block truncate text-[13px] font-semibold text-text">{p.name}</span>
                  <span class="block truncate text-[11px] text-muted">{p.type} · {p.city}</span>
                </span>
                {living && <span class="flex-none text-[10.5px] font-semibold uppercase tracking-wide text-muted">{living}</span>}
              </a>
            );
          })}
        </div>
      </section>
    )}

    {country.highlights.length > 0 && (
      <section>
        <h2 class="mb-2.5 font-display text-[15px] font-semibold text-text">Why founders build here</h2>
        <ul class="orbit-list flex flex-col gap-2 text-[13px] leading-relaxed text-muted">
          {country.highlights.map((h) => (
            <li>{h}</li>
          ))}
        </ul>
      </section>
    )}

    <p class="text-[11.5px] text-muted">
      Last verified {country.updatedAt}. Visa rules and links change often — always confirm on the official source.
    </p>
  </main>
</Base>
