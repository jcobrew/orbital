---
import Base from '../layouts/Base.astro';
import GlobeView from '../islands/GlobeView.tsx';
import { PROGRAMS } from '../data/programs';
---

<Base
  title="Founder Atlas — 3D Globe of startup programs worldwide"
  description="Explore startup accelerators, incubators, residencies, hacker houses and fellowships on a 3D globe. Spin the globe or pick a program to fly there; dense cities have their own minimaps below. Prefer a list? Browse every program at /explore."
  fullscreen
>
  <!-- Globe.gl (Three.js) needs the DOM; render this island client-only. -->
  <GlobeView programs={PROGRAMS} client:only="react" />
  <div slot="head"></div>
</Base>
